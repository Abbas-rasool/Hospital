@page
@model Hospital.Pages.Pharmacy.PrescriptionsModel
@{
    ViewData["Title"] = "Pharmacy — Prescriptions";
    ViewData["Section"] = "Pharmacy";
}

<h4 class="mb-4">Prescription Queue</h4>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>#</th>
                    <th>Patient</th>
                    <th>MRN</th>
                    <th>Prescribed By</th>
                    <th>Date</th>
                    <th>Status</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var rx in Model.Prescriptions)
                {
                    <tr>
                        <td class="text-muted small">@rx.Id</td>
                        <td class="fw-semibold">@rx.Visit?.Patient?.FirstName @rx.Visit?.Patient?.LastName</td>
                        <td><span class="badge bg-secondary">@rx.Visit?.Patient?.MRN</span></td>
                        <td>@rx.CreatedBy?.FullName</td>
                        <td class="text-muted small">@rx.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                        <td>
                            @if (rx.IsPrinted)
                            {
                                <span class="badge bg-success">Printed</span>
                            }
                            else
                            {
                                <span class="badge bg-warning text-dark">Pending</span>
                            }
                        </td>
                        <td>
                            <a asp-page="/Pharmacy/PrintPrescription" asp-route-id="@rx.Id"
                               class="btn btn-sm btn-outline-primary">View / Print</a>
                        </td>
                    </tr>
                }
                @if (!Model.Prescriptions.Any())
                {
                    <tr><td colspan="7" class="text-center text-muted py-4">No prescriptions pending.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
