@page
@model Hospital.Pages.LoginModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Sign In — Hospital</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <style>
        body { background: #eef2f7; display: flex; align-items: center; justify-content: center; min-height: 100vh; margin: 0; }
        .login-card { width: 400px; border: none; border-radius: 12px; box-shadow: 0 8px 32px rgba(0,0,0,.12); overflow: hidden; }
        .login-header { background: #1a4f8a; color: white; padding: 2.5rem 2rem; text-align: center; }
        .login-header h4 { font-size: 1.5rem; font-weight: 700; margin-bottom: .25rem; }
        .login-body { padding: 2rem; background: white; }
        .btn-signin { background: #1a4f8a; border: none; }
        .btn-signin:hover { background: #15406f; }
    </style>
</head>
<body>
    <div class="login-card">
        <div class="login-header">
            <div style="font-size:2.5rem; margin-bottom:.5rem;">&#x2764;</div>
            <h4>Hospital System</h4>
            <small class="opacity-75">Sign in to continue</small>
        </div>
        <div class="login-body">
            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="alert alert-danger py-2 small">@Model.ErrorMessage</div>
            }
            <form method="post">
                @Html.AntiForgeryToken()
                <div class="mb-3">
                    <label class="form-label fw-semibold">Username</label>
                    <input name="Username" type="text" class="form-control" autofocus required autocomplete="username" />
                </div>
                <div class="mb-4">
                    <label class="form-label fw-semibold">Password</label>
                    <input name="Password" type="password" class="form-control" required autocomplete="current-password" />
                </div>
                <button type="submit" class="btn btn-primary btn-signin w-100 fw-semibold">Sign In</button>
            </form>
        </div>
    </div>
</body>
</html>
