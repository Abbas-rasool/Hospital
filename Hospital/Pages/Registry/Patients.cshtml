@page
@model Hospital.Pages.Registry.PatientsModel
@{
    ViewData["Title"] = "Registry — Patients";
    ViewData["Section"] = "Registry";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0">Patient Registry</h4>
    <a asp-page="/Registry/NewPatient" class="btn btn-primary">+ New Patient</a>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-header bg-white">
        <form method="get" class="d-flex gap-2">
            <input name="q" value="@Model.Query" type="search" class="form-control" placeholder="Search by name, MRN, or phone..." style="max-width:360px;" />
            <button type="submit" class="btn btn-outline-primary">Search</button>
            @if (!string.IsNullOrEmpty(Model.Query))
            {
                <a asp-page="/Registry/Patients" class="btn btn-outline-secondary">Clear</a>
            }
        </form>
    </div>
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>MRN</th>
                    <th>Full Name</th>
                    <th>Gender</th>
                    <th>DOB</th>
                    <th>Phone</th>
                    <th>Registered</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in Model.Patients)
                {
                    <tr>
                        <td><span class="badge bg-secondary">@p.MRN</span></td>
                        <td class="fw-semibold">@p.FirstName @p.LastName</td>
                        <td>@p.Gender</td>
                        <td>@p.DateOfBirth.ToString("dd/MM/yyyy")</td>
                        <td>@p.Phone</td>
                        <td class="text-muted small">@p.CreatedAt.ToString("dd/MM/yyyy")</td>
                        <td>
                            <a asp-page="/Registry/PatientDetail" asp-route-id="@p.Id"
                               class="btn btn-sm btn-outline-primary">View</a>
                        </td>
                    </tr>
                }
                @if (!Model.Patients.Any())
                {
                    <tr><td colspan="7" class="text-center text-muted py-4">No patients found.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
